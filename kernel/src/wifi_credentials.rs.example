//! Boot Wi-Fi credentials -- TEMPLATE. Copy it, do not edit it in place:
//!
//!   cp kernel/src/wifi_credentials.rs.example kernel/src/wifi_credentials.rs
//!
//! The copy is git-ignored. It really is now -- until 2026-07-15 there was no
//! .gitignore entry and the file was tracked, so following the README meant typing
//! a password into something `git add .` would stage.
//!
//! These are only a FALLBACK. `wifi connect` saves credentials to NVS and the boot
//! path prefers those, so on a board that has connected even once, editing this file
//! and re-flashing changes nothing.

pub const WIFI_SSID: &str = "your-2.4GHz-ssid";
pub const WIFI_PASSWORD: &str = "your-password";
